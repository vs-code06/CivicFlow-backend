{
    "name": "civicflow-backend",
    "version": "1.0.0",
    "description": "Backend API for CivicFlow",
    "main": "server.ts",
    "scripts": {
        "start": "node dist/server.js",
        "dev": "ts-node-dev --respawn --transpile-only server.ts",
        "build": "tsc",
        "seed:master": "ts-node src/data/master_Seed.ts",
        "seed:users": "ts-node src/data/users_Seed.ts",
        "seed:complaints": "ts-node src/data/complaints_Seed.ts",
        "seed:bins": "ts-node src/data/bins_Seed.ts",
        "seed:logs": "ts-node src/data/activityLogs_Seed.ts"
    },
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cloudinary": "^1.41.3",
        "colors": "^1.4.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "date-fns": "^4.1.0",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-async-handler": "^1.2.0",
        "google-auth-library": "^10.6.2",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.0.3",
        "multer": "^2.0.2",
        "multer-storage-cloudinary": "^4.0.0",
        "nodemailer": "^8.0.4"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/mongoose": "^5.11.96",
        "@types/multer": "^2.1.0",
        "@types/node": "^25.5.0",
        "@types/nodemailer": "^7.0.11",
        "nodemon": "^3.0.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^6.0.2"
    }
}
